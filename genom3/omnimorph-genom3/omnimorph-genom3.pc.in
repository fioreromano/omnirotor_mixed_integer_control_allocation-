# pkg-config file for omnimorph interface and codels library
#
prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@
datarootdir=@datarootdir@
idldir=@datadir@/idl

Name: omnimorph-genom3
Description: omnimorph interface and codels library
Version: @PACKAGE_VERSION@
Requires: @requires_SPEC@
Cflags: -I${includedir} -I${idldir}
Libs: -L${libdir} -lomnimorph_codels
Libs.private: @codels_requires_LIBS@
