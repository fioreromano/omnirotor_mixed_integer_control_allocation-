# pkg-config file for uninstalled omnimorph interface and codels library
#
prefix=@abs_top_builddir@
libdir=${prefix}/codels
includedir=${prefix}/codels

Name: omnimorph-genom3
Description: omnimorph interface and codels library
Version: @PACKAGE_VERSION@
Requires: @requires_SPEC@
Libs: ${libdir}/libomnimorph_codels.la
Libs.private: @codels_requires_LIBS@
