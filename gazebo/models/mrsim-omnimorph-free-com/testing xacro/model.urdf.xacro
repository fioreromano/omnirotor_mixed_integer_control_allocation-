      <visual name="main_frame">
        <pose>0 0 0 0 0 0</pose>
	<geometry>
            <mesh>
		<uri>model://mrsim-omnimorph/omnicopter_frame.stl</uri>
         <scale>0.001 0.001 0.001 </scale>
	    </mesh>
	</geometry>
        <material>
          <ambient>0 0 0 0.8</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>  
     </link>


    <link name="m1">
       <pose>${abc} ${abc} ${abc} 0 0 0 </pose>
        <inertial>
        <mass>${m_mass}</mass>
        <inertia>
          <ixx>${m_Ixx}</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>${m_Iyy}</iyy><iyz>0</iyz>
          <izz>${m_Izz}</izz>
        </inertia>
      </inertial>
      <visual name="motor">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
        <mesh>
        <uri>model://mrsim-omnimorph/brushless_motor_f40.stl</uri>
        <scale>0.001 0.001 0.001 </scale>
         </mesh>
        </geometry>
       <material>
          <ambient>76 6 6 0.65</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>
     <visual name="rot_axis">
        <pose>0 0 0 0 0 1.5708</pose>
        <geometry>
        <mesh>
        <uri>model://mrsim-omnimorph/rotationaxis.stl</uri>
        <scale>0.001 0.001 0.001 </scale>
         </mesh>
        </geometry>
      </visual>     
    </link>
   <link name="m2">
       <pose>-${abc} ${abc} ${abc} 0 0 0 </pose>
        <inertial>
        <mass>${m_mass}</mass>
        <inertia>
          <ixx>${m_Ixx}</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>${m_Iyy}</iyy><iyz>0</iyz>
          <izz>${m_Izz}</izz>
        </inertia>
      </inertial>
      <visual name="motor">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
        <mesh>
        <uri>model://mrsim-omnimorph/brushless_motor_f40.stl</uri>
        <scale>0.001 0.001 0.001 </scale>
